{
  "name": "youtube-hello-extension",
  "version": "1.0.0",
  "description": "YouTube字幕をAIで要約するChrome拡張機能",
  "scripts": {
    "prebuild": "node scripts/sync-version.cjs",
    "predev": "node scripts/sync-version.cjs",
    "pretest": "node scripts/sync-version.cjs",
    "sync-version": "node scripts/sync-version.cjs",
    "test": "jest --coverage",
    "build": "vite build",
    "dev": "vite",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transformIgnorePatterns": [
      "node_modules/(?!marked|dompurify)"
    ],
    "moduleNameMapper": {
      "\\.(css|less)$": "<rootDir>/tests/__mocks__/styleMock.js"
    }
  },
  "devDependencies": {
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/preset-env": "^7.29.7",
    "@crxjs/vite-plugin": "^2.7.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.8.4",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "dompurify": "^3.4.8",
    "marked": "^18.0.5"
  }
}
